# Copy these values into Coolify's Environment Variables for the Docker Compose resource.
# Do not commit real secrets.

POSTGRES_DB=kwikmenu
POSTGRES_USER=kwikmenu
POSTGRES_PASSWORD=change-me-strong-password
# Same password as POSTGRES_PASSWORD, URL-encoded if it contains special characters.
# Example: ! -> %21, @ -> %40
POSTGRES_PASSWORD_ENCODED=change-me-strong-password

AUTH_COOKIE_DOMAIN=.kwikme.nu
AUTH_SESSION_COOKIE_NAME=kwikmenu_session
AUTH_SESSION_TTL_HOURS=720

MENU_IMPORT_FRONTEND_ORIGIN=https://app.kwikme.nu
MENU_IMPORT_API_URL=https://app.kwikme.nu
PUBLIC_MENU_BASE_URL=https://app.kwikme.nu
ADMIN_FRONTEND_ORIGIN=https://admin.kwikme.nu
OPENROUTER_REFERER=https://app.kwikme.nu

OPENROUTER_API_KEY=
MENU_IMPORT_MODEL=openai/gpt-4.1-mini
MENU_IMPORT_MAX_COMPLETION_TOKENS=12000
MENU_IMPORT_RETRY_MAX_COMPLETION_TOKENS=24000
MENU_NORMALIZATION_MAX_COMPLETION_TOKENS=24000
MENU_IMPORT_REQUEST_TIMEOUT_SECONDS=180
MENU_IMPORT_PAGE_PARSE_ATTEMPTS=3
MENU_IMPORT_TASK_SOFT_TIME_LIMIT_SECONDS=600
MENU_IMPORT_TASK_HARD_TIME_LIMIT_SECONDS=660

CURRENCY=USD
BILLING_TRIAL_DAYS=14
BILLING_DEFAULT_PLAN_CODE=basic

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_SUCCESS_URL=https://app.kwikme.nu/dashboard/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=https://app.kwikme.nu/dashboard/billing/fail
STRIPE_AUTOMATIC_TAX_ENABLED=false

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

MEDIA_STORAGE_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
MEDIA_STORAGE_BUCKET=kwikmenu-en-media
MEDIA_STORAGE_ACCESS_KEY_ID=
MEDIA_STORAGE_SECRET_ACCESS_KEY=
MEDIA_STORAGE_REGION=auto
MEDIA_STORAGE_PUBLIC_BASE_URL=https://media.kwikme.nu

HELP_REQUESTS_TELEGRAM_BOT_TOKEN=
HELP_REQUESTS_TELEGRAM_CHAT_ID=
N8N_WEBHOOK_TOKEN=

UNISENDER_API_KEY=
UNISENDER_SERVICE_TYPE=go
UNISENDER_SENDER_EMAIL=support@kwikme.nu
UNISENDER_SENDER_NAME=KwikMenu
UNISENDER_CLASSIC_LIST_ID=
UNISENDER_WEBHOOK_URL=

WORKER_CONCURRENCY=1
